{
  "name": "10s",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run db:migrate",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:sync": "tsx scripts/db-migrate.ts --push",
    "db:normalize-emails": "tsx scripts/normalize-emails.ts",
    "db:migrate-watches": "tsx scripts/migrate-watches-to-days.ts",
    "maintain": "tsx scripts/maintain.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@tailwindcss/postcss": "^4",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "got": "^14.6.6",
    "https-proxy-agent": "^7.0.6",
    "jose": "^6.1.3",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "node-fetch": "^3.3.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "user-agents": "^1.1.669"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@types/user-agents": "^1.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tsx": "^4.21.0",
    "vitest": "^2.0.0"
  }
